rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isNeuronOwner() { return isSignedIn() && request.auth.uid == resource.data.userId; }
    function incoming() { return request.resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // User Profile Validation
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'tier', 'createdAt', 'updatedAt']) 
        && data.email is string && data.email.size() <= 200
        && data.name is string && data.name.size() <= 100
        && data.tier in ['Free', 'Pro', 'Quantum']
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
        && incoming().diff(resource.data).affectedKeys().hasOnly(['name', 'goal', 'avatar', 'tier', 'updatedAt'])
        && incoming().updatedAt == request.time
        && (incoming().tier == resource.data.tier || request.auth.token.email.matches('.*@glia\\.core$')); // Simulate admin check or tier logic
      
      allow delete: if false; // Profiles are permanent for now
    }

    // Neuron Validation
    function isValidNeuron(data) {
      return data.keys().hasAll(['userId', 'type', 'title', 'content', 'createdAt', 'updatedAt'])
        && data.userId == request.auth.uid
        && data.type in ['Insight', 'Project', 'Contact', 'Research', 'System']
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 50000
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    match /neurons/{neuronId} {
      allow get: if isNeuronOwner();
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidNeuron(incoming());
      allow update: if isNeuronOwner() 
        && incoming().diff(resource.data).affectedKeys().hasOnly(['title', 'content', 'metadata', 'color', 'updatedAt'])
        && incoming().updatedAt == request.time;
      allow delete: if isNeuronOwner();
    }
  }
}
